        "jsCode": "const headers = $input.first().json.headers || {};\nconst aaff_key = (headers['x-aaff-key'] || '').trim();\n\nif (!aaff_key) {\n  return [{ json: { _status: 400, error: 'Missing X-AAFF-Key header' } }];\n}\nif (!/^[A-Za-z0-9]{20,40}$/.test(aaff_key)) {\n  return [{ json: { _status: 400, error: 'Invalid X-AAFF-Key format' } }];\n}\n\n// Recoge filtros opcionales de query\nconst q = $input.first().json.query || {};\nconst filters = {\n  cups: q.cups || '',\n  init_date: q.init_date || '',\n  end_date: q.end_date || '',\n  bill_date_init: q.bill_date_init || '',\n  bill_date_end: q.bill_date_end || '',\n  limit: q.limit ? Number(q.limit) : 200,\n  offset: q.offset ? Number(q.offset) : 0,\n  bill_status: q.bill_status || '',\n  payment_status: q.payment_status || '',\n};\n\nreturn [{ json: { _status: 200, aaff_key, filters } }];\n"
