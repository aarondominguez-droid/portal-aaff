      "parameters": {
        "jsCode": "// Construye channel_name + contractId→id_company map\nconst data = $input.first().json;\nconst contracts = data.listContractsExtended || [];\n\nif (!contracts.length) {\n  return [{ json: { _status: 404, error: 'No hay contratos para este canal — sin facturas posibles', channel_name: '', contractToCompany: {}, contractToCups: {}, contractToAlias: {} } }];\n}\n\nconst channel_name = contracts[0].channel_name || '';\nconst contractToCompany = {};\nconst contractToCups = {};\nconst contractToAlias = {};\nconst contractToComunidadNombre = {};\n\n// Reusamos la misma lógica de alias del workflow contratos\nconst ALIAS_MAP = {\n  'ASC':'Ascensor','ESC':'Escalera','PRK':'Parking','PEK':'Parking','POR':'Portería','PORT':'Portería',\n  'BJO':'Bajos','GARAJE':'Garaje','LOCALES':'Locales','LOCAL':'Local','SG':'Servicios generales',\n  'COMUN':'Servicios comunes','PIS':'Piscina'\n};\nfunction deriveAlias(siteAddress) {\n  if (!siteAddress) return 'Suministro';\n  const parts = String(siteAddress).split(',').map(p=>p.trim()).filter(Boolean);\n  const last = parts[parts.length-1] || '';\n  const upper = last.toUpperCase();\n  if (ALIAS_MAP[upper]) return ALIAS_MAP[upper];\n  const tokens = upper.split(/\\s+/);\n  if (ALIAS_MAP[tokens[0]]) {\n    const head = ALIAS_MAP[tokens[0]];\n    const tail = tokens.slice(1).join(' ');\n    return tail ? `${head} ${tail.toLowerCase()}` : head;\n  }\n  return last.charAt(0).toUpperCase() + last.slice(1).toLowerCase();\n}\n\nfor (const c of contracts) {\n  const id = String(c.id);\n  contractToCompany[id] = String(c.id_company || '0');\n  contractToCups[id] = c.CUPS || '';\n  contractToAlias[id] = deriveAlias(c.site_address);\n  contractToComunidadNombre[id] = c.name || c.account_holder || '';\n}\n\n// Pasamos los filtros del paso anterior\nconst prev = $('Resolve channel_code1').first().json;\n\nreturn [{\n  json: {\n    _status: 200,\n    channel_name,\n    filters: prev.filters,\n    contractToCompany,\n    contractToCups,\n    contractToAlias,\n    contractToComunidadNombre,\n  }\n}];\n"
