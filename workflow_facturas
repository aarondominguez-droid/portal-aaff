      "parameters": {
        "jsCode": "// Transform Nemon bills → frontend FACTURAS\nconst input = $input.first().json;\nconst bills = input.list_bills || (input.error && []) || [];\n\n// Mapas que vienen de Build Contract Map\nconst maps = $('Build Contract Map').first().json;\nconst contractToCompany = maps.contractToCompany || {};\nconst contractToCups    = maps.contractToCups    || {};\nconst contractToAlias   = maps.contractToAlias   || {};\nconst contractToComunidadNombre = maps.contractToComunidadNombre || {};\n\nfunction toNum(v) { const n = Number(v); return Number.isFinite(n) ? n : 0; }\nfunction toFixed2(n) { return Math.round(n * 100) / 100; }\n\nconst MESES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];\nfunction formatPeriodo(initStr, endStr) {\n  if (!initStr || !endStr || initStr === '0000-00-00') return '';\n  const ini = new Date(initStr);\n  const fin = new Date(endStr);\n  if (isNaN(ini) || isNaN(fin)) return `${initStr} – ${endStr}`;\n  const sameMonth = ini.getMonth() === fin.getMonth() && ini.getFullYear() === fin.getFullYear();\n  if (sameMonth) return `${MESES[ini.getMonth()]} ${ini.getFullYear()}`;\n  return `${MESES[ini.getMonth()]} ${ini.getFullYear()} – ${MESES[fin.getMonth()]} ${fin.getFullYear()}`;\n}\nfunction parseDateParts(dateStr) {\n  // Devuelve {year, mesIdx} o {year:null, mesIdx:null} si no parseable.\n  // Usamos init_period (inicio del periodo facturado) como referencia primaria.\n  if (!dateStr || dateStr === '0000-00-00' || dateStr === '1900-01-01') return { year: null, mesIdx: null };\n  const d = new Date(dateStr);\n  if (isNaN(d)) return { year: null, mesIdx: null };\n  return { year: d.getFullYear(), mesIdx: d.getMonth() };\n}\n\n// Mapear estado de pago a algo de UI\nfunction mapEstado(payment_status, bill_maturity) {\n  const ps = (payment_status || '').toLowerCase();\n  if (ps.includes('pagad')) return 'pagada';\n  if (ps.includes('impag')) return 'vencida';\n  if (ps.includes('pendient')) {\n    // Si la fecha de vencimiento ya pasó, es vencida\n    if (bill_maturity && bill_maturity !== '0000-00-00' && bill_maturity !== '1900-01-01') {\n      const d = new Date(bill_maturity);\n      if (!isNaN(d) && d < new Date()) return 'vencida';\n    }\n    return 'pendiente';\n  }\n  return ps || 'desconocido';\n}\n\nconst FACTURAS = bills.map(b => {\n  const total = toNum(b.total);\n  const energia = toNum(b.energy);\n  const potencia = toNum(b.potence);\n  const impuestoElectricidad = toNum(b.electric_tax);\n  const alquilerEquipos = toNum(b.rents);\n  const iva = toNum(b.vat_tax);\n  const otros = toFixed2(\n    toNum(b.regularization) + toNum(b.fees) + toNum(b.others_with_electric_tax) +\n    toNum(b.others_without_electric_tax) + toNum(b.excess_potence) + toNum(b.excess_reactive)\n  );\n\n  const consumoKwh = ['energy_p1','energy_p2','energy_p3','energy_p4','energy_p5','energy_p6']\n    .reduce((acc, k) => acc + toNum(b[k]), 0);\n\n  const contractId = String(b.contract_idcontract || '');\n  // year/mesIdx → preferimos init_period (mes facturado), fallback a emission_date.\n  const fromInit = parseDateParts(b.init_period);\n  const fromEmis = parseDateParts(b.emission_date);\n  const year   = fromInit.year   != null ? fromInit.year   : fromEmis.year;\n  const mesIdx = fromInit.mesIdx != null ? fromInit.mesIdx : fromEmis.mesIdx;\n\n  return {\n    id: String(b.id),\n    numero: b.bill_number || b.pseudo_bill_number || '',\n    suministroId: contractId,\n    cups: b.site_code || contractToCups[contractId] || '',\n    comunidadId: contractToCompany[contractId] || '',\n    comunidadNombre: contractToComunidadNombre[contractId] || '',\n    alias: contractToAlias[contractId] || '',\n    fechaEmision: b.emission_date || '',\n    fechaVencimiento: b.bill_maturity || '',\n    periodo: formatPeriodo(b.init_period, b.end_period),\n    initPeriodo: b.init_period || '',\n    endPeriodo: b.end_period || '',\n    year,\n    mesIdx,\n    consumoKwh: Math.round(consumoKwh),\n    importe: toFixed2(total),\n    estado: mapEstado(b.payment_status, b.bill_maturity),\n    estadoGestion: b.managment_name || '',\n    desglose: {\n      energia: toFixed2(energia),\n      potencia: toFixed2(potencia),\n      impuestoElectricidad: toFixed2(impuestoElectricidad),\n      alquilerEquipos: toFixed2(alquilerEquipos),\n      iva: toFixed2(iva),\n      otros,\n    },\n    // Filenames para descargar PDF (frontend los pasará a /api/factura/pdf)\n    pdfFilename: b.link || '',\n    pdfDraftFilename: b.link_draft || '',\n    contractCode: b.contract_code || '',\n    tarifa: b.tariff || '',\n  };\n});\n\nreturn [{\n  json: {\n    ok: true,\n    counts: { facturas: FACTURAS.length },\n    FACTURAS,\n  }\n}];\n"
      },
